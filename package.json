{
  "name": "weekbox",
  "version": "0.1.0",
  "description": "WeekBox base desktop app",
  "main": "node/Runner.js",
  "scripts": {
    "test": "electron . --developer",
    "build-windows": "electron-builder --win",
    "build-linux": "electron-builder --linux",
    "build-all": "electron-builder --win --linux"
  },
  "build": {
    "asar": false,
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "protocols": [
      {
        "name": "WeekBox",
        "schemes": [
          "weekbox"
        ]
      }
    ]
  },
  "author": "WeekBox",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.7.0"
  }
}
